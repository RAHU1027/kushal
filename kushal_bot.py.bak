# Global Prices & Cache
prices = {"1": "1,499", "2": "499", "3": "149", "4": "99", "5": "69", "6": "49"}
f_cache = {}

# --- CAPTIONS ---
T = {
    "1": "😍 <b>80000+ zip file's Channel</b> 💔\nPrice: <b>Rs. {p}</b>",
    "2": "📽️ <b>AVAILABLE VIDEOS COLLECTION</b> 🎁\nOFFER PRICE - <b>{p}/-</b>",
    "3": "🥷 <b>VIP STUFF AVAILABLE</b> 🇨🇦\nPrice: <b>Rs. {p}</b>",
