def get_kb(p):
    m = types.InlineKeyboardMarkup(row_width=1)
    m.add(
        types.InlineKeyboardButton("📽️ WATCH DEMO VIDEO", url="https://t.me/kushal"),
        types.InlineKeyboardButton(f"💎 UNLOCK PREMIUM ({p})", callback_data=f"pay_{p}"),
        types.InlineKeyboardButton("💬 CONTACT ADMIN", url="https://t.me/kushal_admin")
    )
    return m

def send_item(uid, f, p, cap):
    full = os.path.join(PATH, f)
    markup = get_kb(p)
    try:
        if f in f_cache:
            fid = f_cache[f]
            if f.endswith(".mp4"): bot.send_video(uid, fid, caption=cap.format(p=p), parse_mode='HTML', reply_markup=markup)
            else: bot.send_photo(uid, fid, caption=cap.format(p=p), parse_mode='HTML', reply_markup=markup)
            return
        if os.path.exists(full):
            with open(full, 'rb') as file:
                if f.endswith(".mp4"):
                    s = bot.send_video(uid, file, caption=cap.format(p=p), parse_mode='HTML', reply_markup=markup, supports_streaming=True)
                    f_cache[f] = s.video.file_id
                else:
                    s = bot.send_photo(uid, file, caption=cap.format(p=p), parse_mode='HTML', reply_markup=markup)
                    f_cache[f] = s.photo[-1].file_id
    except: pass

@bot.message_handler(commands=['start'])
def start(m):
    kb = types.ReplyKeyboardMarkup(resize_keyboard=True)
    kb.add("English 🇺🇸", "Hindi 🇮🇳")
    bot.send_message(m.chat.id, "<b>Select Language / भाषा चुनें</b>", parse_mode='HTML', reply_markup=kb)

@bot.message_handler(func=lambda m: m.text in ["English 🇺🇸", "Hindi 🇮🇳"])
def store(m):
    uid = m.chat.id
    # Exact Video Order
    d = [("1.jpg",prices["1"],T["1"]), ("1.mp4",prices["2"],T["2"]), ("2.jpg",prices["3"],T["3"]), 
         ("2.mp4",prices["4"],T["4"]), ("3.jpg",prices["5"],T["5"]), ("3.mp4",prices["6"],T["6"])]
    for f, p, cap in d:
        send_item(uid, f, p, cap)
        time.sleep(1.2) # Correct sequence delay

@bot.message_handler(commands=['setprice'])
def set_p(m):
    if m.from_user.id == ADMIN_ID:
        try:
            _, item, val = m.text.split()
            if item in prices:
                prices[item] = val
                bot.reply_to(m, f"✅ Item {item} updated to {val}")
        except: bot.reply_to(m, "Usage: `/setprice 1 500`")

@bot.callback_query_handler(func=lambda call: True)
def cb(call):
    if call.data.startswith("pay"):
        p = call.data.split("_")[1]
        msg = f"💳 <b>UPI:</b> <code>jamnajamna419@okicici</code>\nPay Rs. {p} & send screenshot!"
        bot.send_message(call.message.chat.id, msg, parse_mode='HTML')
    bot.answer_callback_query(call.id)

print("🚀 Bot Started - No Errors!")
bot.infinity_polling()
